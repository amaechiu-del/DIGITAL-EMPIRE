# Paystack API Keys
# Get your keys from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App Configuration
APP_PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# CORS – comma-separated list of allowed origins in production
CORS_ORIGINS=http://localhost:3000

# CSRF secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CSRF_SECRET=change_this_to_a_random_secret_string
